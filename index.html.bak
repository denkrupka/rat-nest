<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🐀 Крысиная нора — Штаб агентов</title>
<style>
html, body {
  margin: 0; padding: 0;
  width: 100vw; height: 100vh;
  overflow: hidden;
  background: #050508;
  font-family: 'Courier New', monospace;
}
canvas {
  width: 100vw; height: 100vh;
  display: block;
  cursor: crosshair;
}
#api-buttons {
  position: fixed;
  top: 10px; left: 10px;
  display: flex; gap: 8px;
  z-index: 200;
}
.api-btn {
  padding: 6px 14px;
  border-radius: 6px;
  border: 1px solid rgba(100,150,255,0.3);
  background: rgba(5,5,20,0.85);
  color: #aaccff;
  font-family: 'Courier New', monospace;
  font-size: 12px;
  cursor: pointer;
  backdrop-filter: blur(4px);
  transition: background 0.2s;
  user-select: none;
}
.api-btn:hover { background: rgba(40,60,120,0.85); }
.api-btn.alert { animation: blink-red 0.5s infinite alternate; }
@keyframes blink-red {
  from { background: rgba(5,5,20,0.85); border-color: rgba(255,50,50,0.6); }
  to   { background: rgba(120,0,0,0.85); border-color: rgba(255,50,50,1); }
}

#title-badge {
  position: fixed;
  top: 10px; right: 10px;
  color: rgba(80,100,150,0.6);
  font-size: 11px;
  letter-spacing: 2px;
  z-index: 200;
  user-select: none;
}

/* Popup */
#backdrop {
  display: none;
  position: fixed; inset: 0;
  z-index: 300;
  background: transparent;
}
#popup {
  display: none;
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(6,8,20,0.97);
  border: 1px solid rgba(80,120,255,0.5);
  border-radius: 10px;
  padding: 20px 24px;
  min-width: 300px;
  color: #ccd6ff;
  font-family: 'Courier New', monospace;
  font-size: 13px;
  z-index: 400;
  box-shadow: 0 0 40px rgba(60,100,255,0.25), inset 0 0 20px rgba(0,0,30,0.5);
}
#popup .p-close {
  position: absolute; top: 10px; right: 14px;
  cursor: pointer; font-size: 18px; color: #445;
  transition: color 0.2s; line-height: 1;
}
#popup .p-close:hover { color: #aaccff; }
#popup .p-name { font-size: 17px; font-weight: bold; color: #fff; margin-bottom: 2px; }
#popup .p-role { font-size: 11px; color: #556688; margin-bottom: 12px; }
#popup .p-row {
  display: flex; justify-content: space-between;
  margin: 5px 0; border-bottom: 1px solid rgba(40,60,100,0.3);
  padding-bottom: 4px;
}
#popup .p-label { color: #445577; }
#popup .p-val { color: #99bbee; font-weight: bold; text-align: right; max-width: 160px; word-break: break-word; }
.status-dot {
  display: inline-block; width: 8px; height: 8px;
  border-radius: 50%; margin-right: 5px; vertical-align: middle;
}
.dot-working { background: #44ee88; box-shadow: 0 0 6px #44ee88; }
.dot-idle    { background: #ffaa33; }
.dot-crashed { background: #ff3333; box-shadow: 0 0 6px #ff3333; }
</style>
</head>
<body>

<div id="api-buttons">
  <button class="api-btn" id="btn-claude" onclick="showLimitsPopup('claude')">🤖 Claude ●</button>
  <button class="api-btn" id="btn-gemini" onclick="showLimitsPopup('gemini')">✨ Gemini ●</button>
</div>

<div id="title-badge">🐀 RAT-NEST v2.0</div>

<canvas id="canvas"></canvas>

<div id="backdrop" onclick="closePopup()"></div>
<div id="popup">
  <span class="p-close" onclick="closePopup()">×</span>
  <div id="popup-inner"></div>
</div>

<script>
// ─── Canvas Setup ───────────────────────────────────────────────────────────
const canvas = document.getElementById('canvas');
const ctx    = canvas.getContext('2d');

function resizeCanvas() {
  canvas.width  = window.innerWidth;
  canvas.height = window.innerHeight;
}
resizeCanvas();
window.addEventListener('resize', resizeCanvas);

// ─── Global State ───────────────────────────────────────────────────────────
let statusData = null;
let agents     = [];
let limitsData = {};
let lastLoadTime = 0;

// Per-mouse animation state
const mouseAnim = {};
// Ambulance states
const ambulances = {};

// ─── Mouse Configurations ───────────────────────────────────────────────────
const MOUSE_CONFIGS = [
  {
    key: 'shnyir00', nameRu: 'Шнырь',
    body: '#8a8a9e', head: '#7a7a8e', ear: '#cc6677',
    eye: '#ff3333', eyeGlow: '#ff0000',
    accent: '#ffdd00', accessory: 'star',
    fat: false
  },
  {
    key: 'miron01', nameRu: 'Мирон',
    body: '#8B6530', head: '#7a5520', ear: '#aa7744',
    eye: '#4488ff', eyeGlow: '#2266cc',
    accent: '#cc9944', accessory: 'glasses_rect',
    fat: false
  },
  {
    key: 'zhirobas02', nameRu: 'Жиробас',
    body: '#556688', head: '#445577', ear: '#6677aa',
    eye: '#ccddff', eyeGlow: '#aabbdd',
    accent: '#8899bb', accessory: 'headphones',
    fat: true
  },
  {
    key: 'shustrik03', nameRu: 'Шустрик',
    body: '#d8d8e8', head: '#c8c8d8', ear: '#ffaaaa',
    eye: '#222233', eyeGlow: '#444455',
    accent: '#cc2222', accessory: 'cap',
    fat: false
  },
  {
    key: 'skozliky04', nameRu: 'Скользкий',
    body: '#1e1e2e', head: '#181828', ear: '#2a2a3e',
    eye: '#00ffaa', eyeGlow: '#00cc88',
    accent: '#333366', accessory: 'cloak',
    fat: false
  },
  {
    key: 'tykovka05', nameRu: 'Тыковка',
    body: '#e08830', head: '#c87820', ear: '#cc6610',
    eye: '#ffffff', eyeGlow: '#ffeecc',
    accent: '#ff9922', accessory: 'tablet',
    fat: false
  },
  {
    key: 'hrustik06', nameRu: 'Хрустик',
    body: '#3a7a3a', head: '#2a6a2a', ear: '#4a8a4a',
    eye: '#ffff44', eyeGlow: '#cccc00',
    accent: '#66aa44', accessory: 'magnify',
    fat: false
  },
  {
    key: 'gryzik07', nameRu: 'Грызик',
    body: '#2244cc', head: '#1a3aaa', ear: '#3355dd',
    eye: '#eeeeff', eyeGlow: '#bbbbff',
    accent: '#4466ff', accessory: 'phone',
    fat: false
  }
];

// ─── Layout Helpers ─────────────────────────────────────────────────────────
function W() { return canvas.width; }
function H() { return canvas.height; }
function officeH() { return H() * 0.55; }
function denY()    { return H() * 0.55; }
function denH()    { return H() * 0.45; }

// Station positions (8 desks, 2 rows × 4)
function getStations() {
  const w = W(), oH = officeH();
  const cols = 4, rows = 2;
  const st = [];
  for (let r = 0; r < rows; r++) {
    for (let c = 0; c < cols; c++) {
      st.push({
        x: w * (c * 2 + 1) / (cols * 2),
        y: oH * (r * 2 + 1.2) / (rows * 2)
      });
    }
  }
  return st;
}

// Den rest positions (8 spots in den)
function getDenSpots() {
  const w = W(), dY = denY(), dH = denH();
  return [
    { x: w * 0.08, y: dY + dH * 0.45 }, // bed area L
    { x: w * 0.16, y: dY + dH * 0.55 },
    { x: w * 0.30, y: dY + dH * 0.50 }, // couch area
    { x: w * 0.42, y: dY + dH * 0.55 },
    { x: w * 0.60, y: dY + dH * 0.45 }, // microwave area
    { x: w * 0.72, y: dY + dH * 0.55 }, // arcade area
    { x: w * 0.85, y: dY + dH * 0.45 }, // toilet
    { x: w * 0.93, y: dY + dH * 0.55 }  // medkit
  ];
}

// ─── Draw Environment ────────────────────────────────────────────────────────
function drawOffice() {
  const w = W(), oH = officeH();

  // Back wall gradient
  const wallG = ctx.createLinearGradient(0, 0, 0, oH);
  wallG.addColorStop(0, '#080d18');
  wallG.addColorStop(1, '#0e1a2e');
  ctx.fillStyle = wallG;
  ctx.fillRect(0, 0, w, oH);

  // Floor grid
  ctx.strokeStyle = 'rgba(30,60,120,0.25)';
  ctx.lineWidth = 1;
  const gs = Math.round(w / 24);
  for (let x = 0; x <= w; x += gs) {
    ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, oH); ctx.stroke();
  }
  for (let y = 0; y <= oH; y += gs) {
    ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(w, y); ctx.stroke();
  }

  // Ceiling lights
  const lightPositions = [0.2, 0.4, 0.6, 0.8];
  for (const lp of lightPositions) {
    const lx = w * lp;
    // Light bar
    ctx.fillStyle = 'rgba(180,220,255,0.9)';
    ctx.fillRect(lx - 35, 0, 70, 5);
    // Glow
    const grd = ctx.createRadialGradient(lx, 0, 0, lx, 0, 100);
    grd.addColorStop(0, 'rgba(150,200,255,0.12)');
    grd.addColorStop(1, 'rgba(150,200,255,0)');
    ctx.fillStyle = grd;
    ctx.beginPath();
    ctx.ellipse(lx, 30, 80, 80, 0, 0, Math.PI * 2);
    ctx.fill();
  }

  // Floor separator line
  ctx.strokeStyle = 'rgba(30,60,120,0.5)';
  ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(0, oH); ctx.lineTo(w, oH); ctx.stroke();

  // Draw desks + monitors
  const stations = getStations();
  for (let i = 0; i < 8; i++) {
    const { x, y } = stations[i];
    drawDesk(x, y, i);
  }
}

function drawDesk(x, y, idx) {
  const deskW = W() * 0.11;
  const deskH = H() * 0.025;

  // Desk shadow
  ctx.fillStyle = 'rgba(0,0,0,0.4)';
  ctx.beginPath();
  ctx.ellipse(x, y + deskH + 4, deskW * 0.5, 6, 0, 0, Math.PI * 2);
  ctx.fill();

  // Desk legs
  ctx.fillStyle = '#1a1a2a';
  ctx.fillRect(x - deskW * 0.4, y + deskH, 6, 14);
  ctx.fillRect(x + deskW * 0.4 - 6, y + deskH, 6, 14);

  // Desk surface
  ctx.fillStyle = '#1e2438';
  ctx.beginPath();
  ctx.roundRect(x - deskW / 2, y, deskW, deskH, 3);
  ctx.fill();
  ctx.strokeStyle = 'rgba(60,90,160,0.5)';
  ctx.lineWidth = 1;
  ctx.stroke();

  // Monitor stand
  const monW = deskW * 0.38;
  const monH = H() * 0.085;
  const monX = x - monW / 2;
  const monY = y - monH - 4;

  ctx.fillStyle = '#0d0d14';
  ctx.fillRect(x - 4, monY + monH, 8, 8); // stand base
  ctx.fillRect(x - 2, monY + monH - 8, 4, 10); // neck

  // Monitor bezel
  ctx.fillStyle = '#111118';
  ctx.beginPath();
  ctx.roundRect(monX, monY, monW, monH, 3);
  ctx.fill();

  // Screen
  const sMargin = 3;
  const screenG = ctx.createLinearGradient(monX + sMargin, monY + sMargin, monX + sMargin, monY + monH - sMargin);
  screenG.addColorStop(0, '#051525');
  screenG.addColorStop(1, '#020d1a');
  ctx.fillStyle = screenG;
  ctx.fillRect(monX + sMargin, monY + sMargin, monW - sMargin * 2, monH - sMargin * 2);

  // Screen content (deterministic code lines based on idx)
  const lineColors = ['#00ff88', '#4488ff', '#ff8844', '#ffdd00', '#cc88ff'];
  const lineWidths = [[0.2,0.6,0.3,0.8,0.5],[0.4,0.3,0.7,0.2,0.6],[0.5,0.8,0.2,0.4,0.9],[0.3,0.5,0.7,0.1,0.6],[0.6,0.2,0.5,0.8,0.3],[0.1,0.7,0.4,0.6,0.2],[0.8,0.3,0.5,0.1,0.7],[0.4,0.6,0.2,0.8,0.5]];
  const lw = lineWidths[idx % 8];
  const sw = monW - sMargin * 2 - 6;
  const sh = monH - sMargin * 2 - 4;
  const lineH = sh / 6;
  for (let li = 0; li < 5; li++) {
    ctx.fillStyle = lineColors[li % lineColors.length];
    ctx.globalAlpha = 0.7;
    ctx.fillRect(monX + sMargin + 3, monY + sMargin + 3 + li * lineH, sw * lw[li], 2);
  }
  ctx.globalAlpha = 1;

  // Keyboard
  ctx.fillStyle = '#1a1a2e';
  ctx.beginPath();
  ctx.roundRect(x - deskW * 0.35, y + 2, deskW * 0.7, deskH * 0.55, 2);
  ctx.fill();
  ctx.fillStyle = 'rgba(60,90,160,0.3)';
  for (let ki = 0; ki < 8; ki++) {
    const kx = x - deskW * 0.3 + ki * (deskW * 0.6 / 8);
    ctx.fillRect(kx, y + 3, deskW * 0.06, 3);
  }
}

function drawDen() {
  const w = W(), dY = denY(), dH = denH();

  // Den background
  const denG = ctx.createLinearGradient(0, dY, 0, dY + dH);
  denG.addColorStop(0, '#0a0810');
  denG.addColorStop(1, '#050408');
  ctx.fillStyle = denG;
  ctx.fillRect(0, dY, w, dH);

  // Cave texture - irregular rocky feel
  ctx.strokeStyle = 'rgba(30,25,40,0.6)';
  ctx.lineWidth = 1;
  // Horizontal cracks
  for (let y = dY + 20; y < dY + dH; y += 30) {
    ctx.beginPath();
    ctx.moveTo(0, y + (Math.sin(y * 0.1) * 5));
    for (let x = 0; x < w; x += 40) {
      ctx.lineTo(x, y + (Math.sin(x * 0.05 + y * 0.1) * 8));
    }
    ctx.stroke();
  }

  // Pipe along ceiling
  ctx.fillStyle = '#1a1520';
  ctx.fillRect(0, dY, w, 6);
  // Pipe rivets
  ctx.fillStyle = '#2a2030';
  for (let px = 30; px < w; px += 80) {
    ctx.beginPath();
    ctx.arc(px, dY + 3, 3, 0, Math.PI * 2);
    ctx.fill();
  }

  // Glowing cables on ceiling
  ctx.strokeStyle = 'rgba(0,180,255,0.2)';
  ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(0, dY + 10); ctx.lineTo(w, dY + 10); ctx.stroke();
  ctx.strokeStyle = 'rgba(255,100,0,0.15)';
  ctx.beginPath(); ctx.moveTo(0, dY + 15); ctx.lineTo(w * 0.6, dY + 15); ctx.stroke();

  // Floor
  ctx.fillStyle = 'rgba(10,8,15,0.8)';
  ctx.fillRect(0, dY + dH - 20, w, 20);

  // ── Furniture ───────────────────────────────────────────────────────────────

  // BED (left side)
  const bedX = w * 0.06, bedY = dY + dH * 0.28;
  drawBed(bedX, bedY, w * 0.13, dH * 0.35);

  // COUCH
  const couchX = w * 0.26, couchY = dY + dH * 0.38;
  drawCouch(couchX, couchY, w * 0.12, dH * 0.28);

  // MICROWAVE
  const mwX = w * 0.52, mwY = dY + dH * 0.22;
  drawMicrowave(mwX, mwY);

  // ARCADE MACHINE
  const arcX = w * 0.67, arcY = dY + dH * 0.10;
  drawArcade(arcX, arcY, dH * 0.55);

  // TOILET
  const toiletX = w * 0.82, toiletY = dY + dH * 0.25;
  drawToilet(toiletX, toiletY);

  // MEDKIT on wall
  const mkX = w * 0.93, mkY = dY + dH * 0.18;
  drawMedkit(mkX, mkY);

  // Floor label
  ctx.fillStyle = 'rgba(40,30,55,0.8)';
  ctx.font = `bold ${Math.round(H() * 0.012)}px 'Courier New'`;
  ctx.fillText('🐀 НОРА', 10, dY + dH - 5);
}

function drawBed(x, y, w, h) {
  // Frame
  ctx.fillStyle = '#2a1a0e';
  ctx.beginPath(); ctx.roundRect(x, y, w, h, 4); ctx.fill();
  // Mattress
  ctx.fillStyle = '#1a3350';
  ctx.beginPath(); ctx.roundRect(x + 3, y + 5, w - 6, h - 10, 3); ctx.fill();
  // Pillow
  ctx.fillStyle = '#223355';
  ctx.beginPath(); ctx.roundRect(x + 4, y + 6, w - 8, h * 0.25, 3); ctx.fill();
  // Blanket
  ctx.fillStyle = '#2a4a1a';
  ctx.beginPath(); ctx.roundRect(x + 4, y + h * 0.3, w - 8, h * 0.55, 2); ctx.fill();
  // Blanket stripes
  ctx.strokeStyle = 'rgba(50,100,30,0.4)';
  ctx.lineWidth = 1;
  for (let s = 0; s < 3; s++) {
    ctx.beginPath();
    ctx.moveTo(x + 4, y + h * 0.35 + s * 8);
    ctx.lineTo(x + w - 4, y + h * 0.35 + s * 8);
    ctx.stroke();
  }
  // Label
  ctx.fillStyle = 'rgba(100,80,120,0.5)';
  ctx.font = `${Math.round(w * 0.18)}px monospace`;
  ctx.fillText('🛏', x + w * 0.3, y + h * 0.7);
}

function drawCouch(x, y, w, h) {
  // Base
  ctx.fillStyle = '#3a2a1a';
  ctx.beginPath(); ctx.roundRect(x, y + h * 0.35, w, h * 0.65, 4); ctx.fill();
  // Seat
  ctx.fillStyle = '#5a3a20';
  ctx.beginPath(); ctx.roundRect(x + 3, y + h * 0.4, w - 6, h * 0.45, 3); ctx.fill();
  // Back
  ctx.fillStyle = '#4a2e18';
  ctx.beginPath(); ctx.roundRect(x, y, w, h * 0.4, 4); ctx.fill();
  // Armrests
  ctx.fillStyle = '#3a2010';
  ctx.fillRect(x, y + h * 0.3, w * 0.1, h * 0.55);
  ctx.fillRect(x + w * 0.9, y + h * 0.3, w * 0.1, h * 0.55);
  // Label
  ctx.fillStyle = 'rgba(100,80,60,0.5)';
  ctx.font = `${Math.round(w * 0.2)}px monospace`;
  ctx.fillText('🛋', x + w * 0.3, y + h * 0.75);
}

function drawMicrowave(x, y) {
  const mw = 60, mh = 42;
  // Body
  ctx.fillStyle = '#1a1a2a';
  ctx.beginPath(); ctx.roundRect(x, y, mw, mh, 4); ctx.fill();
  ctx.strokeStyle = '#2a2a4a';
  ctx.lineWidth = 1; ctx.stroke();
  // Door window
  ctx.fillStyle = '#050520';
  ctx.beginPath(); ctx.roundRect(x + 5, y + 6, mw * 0.55, mh * 0.65, 3); ctx.fill();
  // Glow (if "active")
  ctx.fillStyle = 'rgba(0,180,50,0.15)';
  ctx.fillRect(x + 6, y + 7, mw * 0.53, mh * 0.63);
  // Control panel
  ctx.fillStyle = '#0d0d1a';
  ctx.fillRect(x + mw * 0.6, y + 5, mw * 0.35, mh - 10);
  // Buttons
  for (let bi = 0; bi < 4; bi++) {
    ctx.fillStyle = bi === 0 ? '#003300' : '#0a0a15';
    ctx.beginPath();
    ctx.roundRect(x + mw * 0.63, y + 8 + bi * 8, mw * 0.28, 5, 1);
    ctx.fill();
  }
  // Label
  ctx.fillStyle = 'rgba(60,100,60,0.5)';
  ctx.font = '10px monospace';
  ctx.fillText('📡', x + mw * 0.6, y - 4);
}

function drawArcade(x, y, h) {
  const aw = h * 0.45, ah = h;
  // Cabinet body
  const arcG = ctx.createLinearGradient(x, y, x + aw, y);
  arcG.addColorStop(0, '#0e0010');
  arcG.addColorStop(0.5, '#1a0030');
  arcG.addColorStop(1, '#0e0010');
  ctx.fillStyle = arcG;
  ctx.beginPath(); ctx.roundRect(x, y, aw, ah, 6); ctx.fill();
  ctx.strokeStyle = '#440088';
  ctx.lineWidth = 1; ctx.stroke();

  // Screen
  const sX = x + aw * 0.1, sY = y + ah * 0.1;
  const sW = aw * 0.8, sH = ah * 0.32;
  ctx.fillStyle = '#050015';
  ctx.beginPath(); ctx.roundRect(sX, sY, sW, sH, 3); ctx.fill();
  // Screen glow
  ctx.fillStyle = 'rgba(200,0,255,0.2)';
  ctx.fillRect(sX + 2, sY + 2, sW - 4, sH - 4);
  // Pixel art on screen
  ctx.fillStyle = 'rgba(255,100,255,0.7)';
  ctx.fillRect(sX + sW * 0.35, sY + sH * 0.3, sW * 0.3, sH * 0.15);
  ctx.fillStyle = 'rgba(100,255,255,0.5)';
  ctx.fillRect(sX + sW * 0.2, sY + sH * 0.55, sW * 0.2, sH * 0.2);
  ctx.fillRect(sX + sW * 0.6, sY + sH * 0.55, sW * 0.2, sH * 0.2);

  // Marquee top glow
  ctx.fillStyle = 'rgba(200,0,255,0.4)';
  ctx.fillRect(x + 2, y + 2, aw - 4, 8);

  // Controls panel
  ctx.fillStyle = '#0a0018';
  ctx.fillRect(x + aw * 0.05, y + ah * 0.5, aw * 0.9, ah * 0.15);
  // Joystick
  ctx.fillStyle = '#ff2200';
  ctx.beginPath(); ctx.arc(x + aw * 0.3, y + ah * 0.57, 5, 0, Math.PI * 2); ctx.fill();
  // Buttons
  const btnCols = ['#ff0000','#00ff00','#0000ff','#ffff00'];
  for (let bi = 0; bi < 4; bi++) {
    ctx.fillStyle = btnCols[bi];
    ctx.beginPath();
    ctx.arc(x + aw * 0.55 + bi * 8, y + ah * 0.57, 3, 0, Math.PI * 2);
    ctx.fill();
  }

  // Side glow
  ctx.fillStyle = 'rgba(180,0,255,0.1)';
  ctx.beginPath();
  ctx.ellipse(x + aw / 2, y + ah / 2, aw, ah * 0.5, 0, 0, Math.PI * 2);
  ctx.fill();

  // Label
  ctx.fillStyle = 'rgba(150,0,200,0.5)';
  ctx.font = '10px monospace';
  ctx.fillText('🎮', x + aw * 0.3, y - 4);
}

function drawToilet(x, y) {
  const tw = 36, th = 52;
  // Tank
  ctx.fillStyle = '#1a1a2e';
  ctx.beginPath(); ctx.roundRect(x - 2, y, tw + 4, th * 0.38, 3); ctx.fill();
  // Bowl
  ctx.fillStyle = '#16162a';
  ctx.beginPath();
  ctx.ellipse(x + tw / 2, y + th * 0.65, tw * 0.5, th * 0.25, 0, 0, Math.PI * 2);
  ctx.fill();
  // Lid
  ctx.fillStyle = '#1e1e36';
  ctx.beginPath();
  ctx.ellipse(x + tw / 2, y + th * 0.55, tw * 0.46, th * 0.18, 0, 0, Math.PI * 2);
  ctx.fill();
  // Water blue tint
  ctx.fillStyle = 'rgba(0,80,180,0.2)';
  ctx.beginPath();
  ctx.ellipse(x + tw / 2, y + th * 0.65, tw * 0.35, th * 0.15, 0, 0, Math.PI * 2);
  ctx.fill();
  // Label
  ctx.fillStyle = 'rgba(60,60,100,0.5)';
  ctx.font = '10px monospace';
  ctx.fillText('🚽', x + tw * 0.1, y - 4);
}

function drawMedkit(x, y) {
  const size = 28;
  // Box
  ctx.fillStyle = '#ffffff';
  ctx.beginPath(); ctx.roundRect(x - size/2, y - size/2, size, size, 3); ctx.fill();
  // Red cross
  ctx.fillStyle = '#dd0000';
  ctx.fillRect(x - size * 0.15, y - size * 0.38, size * 0.3, size * 0.76);
  ctx.fillRect(x - size * 0.38, y - size * 0.15, size * 0.76, size * 0.3);
  // Glow
  ctx.fillStyle = 'rgba(255,0,0,0.1)';
  ctx.beginPath();
  ctx.ellipse(x, y, size, size, 0, 0, Math.PI * 2);
  ctx.fill();
  // Label
  ctx.fillStyle = 'rgba(200,0,0,0.5)';
  ctx.font = '10px monospace';
  ctx.fillText('💊', x - size * 0.3, y - size * 0.7);
}

// ─── Draw Mouse ──────────────────────────────────────────────────────────────
function drawMouse(mx, my, cfg, status, anim, t) {
  ctx.save();
  ctx.translate(mx, my);

  const fat = cfg.fat ? 1.35 : 1.0;
  const crashed = (status === 'crashed');

  if (crashed) {
    ctx.rotate(Math.PI / 2);
    ctx.globalAlpha = 0.5;
  }

  // Scale
  const sc = 0.85;
  ctx.scale(sc, sc);

  // ── Tail ──
  ctx.strokeStyle = cfg.body;
  ctx.lineWidth = 3;
  ctx.lineCap = 'round';
  ctx.beginPath();
  ctx.moveTo(fat * 16, 5);
  ctx.quadraticCurveTo(fat * 38, 20, fat * 48, 0);
  ctx.stroke();

  // ── Legs ──
  const legW = 9, legH = 15;
  const legAnim = anim.legPhase || 0;
  // Working state: slight lean
  const legOff = (status === 'working') ? Math.sin(t * 0.004) * 2 : 0;

  ctx.fillStyle = cfg.body;
  // Left leg
  ctx.beginPath();
  ctx.roundRect(-fat*10 - legW/2, 5, legW, legH + legOff, 3);
  ctx.fill();
  // Right leg
  ctx.beginPath();
  ctx.roundRect(fat*10 - legW/2, 5, legW, legH - legOff, 3);
  ctx.fill();

  // Leg details (feet)
  ctx.fillStyle = cfg.head;
  ctx.beginPath(); ctx.ellipse(-fat*10, 20, legW * 0.6, 5, 0, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.ellipse(fat*10, 20, legW * 0.6, 5, 0, 0, Math.PI * 2); ctx.fill();

  // ── Body (torso) ──
  const bW = 28 * fat, bH = 34;
  ctx.fillStyle = cfg.body;
  ctx.beginPath();
  ctx.ellipse(0, -12, bW / 2, bH / 2, 0, 0, Math.PI * 2);
  ctx.fill();

  // Belly lighter patch
  ctx.fillStyle = cfg.head;
  ctx.globalAlpha = crashed ? 0.3 : 0.5;
  ctx.beginPath();
  ctx.ellipse(0, -10, bW * 0.3, bH * 0.32, 0, 0, Math.PI * 2);
  ctx.fill();
  ctx.globalAlpha = crashed ? 0.5 : 1.0;

  // ── Accessories on body ──
  if (cfg.accessory === 'star') {
    drawStar(ctx, 0, -14, 8, cfg.accent);
  }

  // ── Arms ──
  const armW = 8, armH = 18;
  const armY = -20;
  let armLAngle = 0, armRAngle = 0;
  if (status === 'working') {
    // Typing animation
    const typeCycle = Math.floor(t / 500) % 2;
    armLAngle = typeCycle === 0 ? -0.4 : -0.7;
    armRAngle = typeCycle === 0 ? -0.7 : -0.4;
  }

  // Left arm
  ctx.save();
  ctx.translate(-fat*16, armY);
  ctx.rotate(-0.3 + armLAngle);
  ctx.fillStyle = cfg.body;
  ctx.beginPath(); ctx.roundRect(-armW/2, 0, armW, armH, 3); ctx.fill();
  // Hand
  ctx.fillStyle = cfg.head;
  ctx.beginPath(); ctx.ellipse(0, armH, armW * 0.6, 4, 0, 0, Math.PI * 2); ctx.fill();

  // Hold accessory in left arm if applicable
  if (cfg.accessory === 'tablet') {
    ctx.fillStyle = '#1a1a2a';
    ctx.beginPath(); ctx.roundRect(-6, armH + 4, 14, 20, 2); ctx.fill();
    ctx.fillStyle = '#3355ff';
    ctx.fillRect(-5, armH + 5, 12, 14);
    ctx.fillStyle = 'rgba(100,150,255,0.5)';
    ctx.fillRect(-4, armH + 6, 10, 8);
  }
  if (cfg.accessory === 'phone') {
    ctx.fillStyle = '#0a0a1a';
    ctx.beginPath(); ctx.roundRect(-4, armH + 2, 10, 18, 2); ctx.fill();
    ctx.fillStyle = '#2244cc';
    ctx.fillRect(-3, armH + 4, 8, 12);
    // Notification dot
    ctx.fillStyle = '#ff2244';
    ctx.beginPath(); ctx.arc(4, armH + 3, 3, 0, Math.PI * 2); ctx.fill();
  }
  ctx.restore();

  // Right arm
  ctx.save();
  ctx.translate(fat*16, armY);
  ctx.rotate(0.3 + armRAngle);
  ctx.fillStyle = cfg.body;
  ctx.beginPath(); ctx.roundRect(-armW/2, 0, armW, armH, 3); ctx.fill();
  ctx.fillStyle = cfg.head;
  ctx.beginPath(); ctx.ellipse(0, armH, armW * 0.6, 4, 0, 0, Math.PI * 2); ctx.fill();
  ctx.restore();

  // ── Head ──
  const headR = 16;
  const headY = -40;
  ctx.fillStyle = cfg.head;
  ctx.beginPath();
  ctx.arc(0, headY, headR, 0, Math.PI * 2);
  ctx.fill();

  // ── Ears ──
  const earW = 9, earH = 13;
  ctx.fillStyle = cfg.head;
  // Left ear
  ctx.beginPath();
  ctx.ellipse(-headR * 0.7, headY - headR + 2, earW/2, earH/2, -0.3, 0, Math.PI * 2);
  ctx.fill();
  ctx.fillStyle = cfg.ear;
  ctx.beginPath();
  ctx.ellipse(-headR * 0.7, headY - headR + 2, earW * 0.4, earH * 0.4, -0.3, 0, Math.PI * 2);
  ctx.fill();
  // Right ear
  ctx.fillStyle = cfg.head;
  ctx.beginPath();
  ctx.ellipse(headR * 0.7, headY - headR + 2, earW/2, earH/2, 0.3, 0, Math.PI * 2);
  ctx.fill();
  ctx.fillStyle = cfg.ear;
  ctx.beginPath();
  ctx.ellipse(headR * 0.7, headY - headR + 2, earW * 0.4, earH * 0.4, 0.3, 0, Math.PI * 2);
  ctx.fill();

  // ── Eyes ──
  const eyeX = 6, eyeY = headY - 2;
  if (crashed) {
    // × × eyes
    ctx.strokeStyle = '#ff4444';
    ctx.lineWidth = 2;
    for (const ex of [-eyeX, eyeX]) {
      ctx.beginPath(); ctx.moveTo(ex - 4, eyeY - 4); ctx.lineTo(ex + 4, eyeY + 4); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(ex + 4, eyeY - 4); ctx.lineTo(ex - 4, eyeY + 4); ctx.stroke();
    }
  } else {
    // Normal eyes
    ctx.fillStyle = '#000';
    ctx.beginPath(); ctx.arc(-eyeX, eyeY, 5, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.arc(eyeX, eyeY, 5, 0, Math.PI * 2); ctx.fill();
    // Iris / glow
    ctx.fillStyle = cfg.eye;
    ctx.beginPath(); ctx.arc(-eyeX, eyeY, 3, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.arc(eyeX, eyeY, 3, 0, Math.PI * 2); ctx.fill();
    // Working: glow effect
    if (status === 'working') {
      const glow = ctx.createRadialGradient(-eyeX, eyeY, 0, -eyeX, eyeY, 8);
      glow.addColorStop(0, cfg.eyeGlow + '88');
      glow.addColorStop(1, 'transparent');
      ctx.fillStyle = glow;
      ctx.beginPath(); ctx.arc(-eyeX, eyeY, 8, 0, Math.PI * 2); ctx.fill();
      const glow2 = ctx.createRadialGradient(eyeX, eyeY, 0, eyeX, eyeY, 8);
      glow2.addColorStop(0, cfg.eyeGlow + '88');
      glow2.addColorStop(1, 'transparent');
      ctx.fillStyle = glow2;
      ctx.beginPath(); ctx.arc(eyeX, eyeY, 8, 0, Math.PI * 2); ctx.fill();
    }
    // Highlight
    ctx.fillStyle = 'rgba(255,255,255,0.7)';
    ctx.beginPath(); ctx.arc(-eyeX + 1, eyeY - 2, 1.5, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.arc(eyeX + 1, eyeY - 2, 1.5, 0, Math.PI * 2); ctx.fill();
  }

  // ── Accessories on head ──
  if (cfg.accessory === 'glasses_rect') {
    ctx.strokeStyle = '#8866aa';
    ctx.lineWidth = 1.5;
    ctx.strokeRect(-eyeX - 4, eyeY - 4, 8, 6);
    ctx.strokeRect(eyeX - 4, eyeY - 4, 8, 6);
    ctx.beginPath(); ctx.moveTo(-eyeX + 4, eyeY - 1); ctx.lineTo(eyeX - 4, eyeY - 1); ctx.stroke();
  }
  if (cfg.accessory === 'headphones') {
    ctx.strokeStyle = '#334455';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(0, headY - 3, headR + 3, Math.PI * 1.1, Math.PI * 1.9, false);
    ctx.stroke();
    ctx.fillStyle = '#223344';
    ctx.beginPath(); ctx.ellipse(-headR - 2, headY + 2, 5, 7, 0, 0, Math.PI * 2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(headR + 2, headY + 2, 5, 7, 0, 0, Math.PI * 2); ctx.fill();
  }
  if (cfg.accessory === 'cap') {
    ctx.fillStyle = cfg.accent;
    ctx.beginPath();
    ctx.ellipse(0, headY - headR + 6, headR + 2, 6, 0, Math.PI, Math.PI * 2);
    ctx.fill();
    // Brim to the back
    ctx.fillStyle = cfg.accent;
    ctx.beginPath();
    ctx.ellipse(-headR - 4, headY - headR + 8, 8, 4, -0.3, 0, Math.PI * 2);
    ctx.fill();
  }
  if (cfg.accessory === 'cloak') {
    // Half-face mask
    ctx.fillStyle = '#333344';
    ctx.beginPath();
    ctx.ellipse(0, headY + 4, headR * 0.9, headR * 0.55, 0, 0, Math.PI);
    ctx.fill();
    // Cloak collar
    ctx.fillStyle = cfg.accent;
    ctx.beginPath();
    ctx.moveTo(-bW * 0.6, -4);
    ctx.lineTo(0, -26);
    ctx.lineTo(bW * 0.6, -4);
    ctx.closePath();
    ctx.fill();
  }
  if (cfg.accessory === 'magnify') {
    ctx.strokeStyle = '#cccc00';
    ctx.lineWidth = 2;
    ctx.beginPath(); ctx.arc(-eyeX - 1, eyeY, 6, 0, Math.PI * 2); ctx.stroke();
    ctx.beginPath(); ctx.arc(eyeX - 1, eyeY, 5, 0, Math.PI * 2); ctx.stroke();
    ctx.strokeStyle = '#999900';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.moveTo(-eyeX - 1 + 4, eyeY + 4);
    ctx.lineTo(-eyeX + 7, eyeY + 9);
    ctx.stroke();
  }

  // ── IDLE: ZZZ ──
  if (status === 'idle') {
    const zPhase = Math.floor(t / 1500) % 3;
    ctx.fillStyle = 'rgba(150,180,255,0.8)';
    ctx.font = `bold ${10 + zPhase * 3}px monospace`;
    ctx.fillText('z'.repeat(zPhase + 1), 12 + zPhase * 4, headY - 20 - zPhase * 6);
  }

  // ── CRASHED: Red cross blink ──
  if (crashed) {
    const blinkOn = Math.floor(t / 300) % 2 === 0;
    if (blinkOn) {
      ctx.strokeStyle = '#ff0000';
      ctx.lineWidth = 3;
      ctx.beginPath(); ctx.moveTo(-15, -55); ctx.lineTo(15, -25); ctx.stroke();
      ctx.beginPath(); ctx.moveTo(15, -55); ctx.lineTo(-15, -25); ctx.stroke();
    }
  }

  ctx.restore();
}

function drawStar(ctx, cx, cy, r, color) {
  ctx.fillStyle = color;
  ctx.beginPath();
  for (let i = 0; i < 5; i++) {
    const angle = (i * Math.PI * 4 / 5) - Math.PI / 2;
    const innerAngle = angle + Math.PI * 2 / 10;
    if (i === 0) {
      ctx.moveTo(cx + Math.cos(angle) * r, cy + Math.sin(angle) * r);
    } else {
      ctx.lineTo(cx + Math.cos(angle) * r, cy + Math.sin(angle) * r);
    }
    ctx.lineTo(cx + Math.cos(innerAngle) * (r * 0.4), cy + Math.sin(innerAngle) * (r * 0.4));
  }
  ctx.closePath();
  ctx.fill();
}

// ─── Ambulance ───────────────────────────────────────────────────────────────
function initAmbulance(mouseIdx) {
  const stations = getStations();
  const st = stations[mouseIdx] || { x: W() * 0.5, y: officeH() * 0.5 };
  ambulances[mouseIdx] = {
    x: W() + 60,
    targetX: st.x + 40,
    stationY: st.y + 10,
    phase: 'driving', // driving | stopped | done
    sparkTimer: 0,
    docAnim: 0
  };
}

function updateAndDrawAmbulances(t, dt) {
  for (let i = 0; i < 8; i++) {
    if (!ambulances[i]) continue;
    const amb = ambulances[i];
    const agent = agents[i];

    // If agent recovered → remove ambulance
    if (agent && agent.status !== 'crashed') {
      delete ambulances[i];
      continue;
    }

    if (amb.phase === 'driving') {
      amb.x -= dt * 0.3;
      if (amb.x <= amb.targetX) {
        amb.x = amb.targetX;
        amb.phase = 'stopped';
      }
    } else if (amb.phase === 'stopped') {
      amb.sparkTimer += dt;
      amb.docAnim += dt;
    }

    drawAmbulance(amb.x, amb.stationY, t, amb);
  }
}

function drawAmbulance(x, y, t, amb) {
  const aw = 52, ah = 26;
  const blinkOn = Math.floor(t / 200) % 2 === 0;

  // Van body
  ctx.fillStyle = '#888899';
  ctx.beginPath(); ctx.roundRect(x - aw, y - ah, aw, ah, 4); ctx.fill();

  // Van top
  ctx.fillStyle = '#777788';
  ctx.beginPath(); ctx.roundRect(x - aw + 4, y - ah - 10, aw * 0.65, 12, 3); ctx.fill();

  // Siren on top
  const sirenColor = blinkOn ? '#ff2200' : '#0033ff';
  ctx.fillStyle = sirenColor;
  ctx.beginPath(); ctx.ellipse(x - aw + aw * 0.3, y - ah - 10, 5, 4, 0, 0, Math.PI * 2); ctx.fill();
  // Siren glow
  if (blinkOn) {
    const sg = ctx.createRadialGradient(x - aw + aw * 0.3, y - ah - 10, 0, x - aw + aw * 0.3, y - ah - 10, 20);
    sg.addColorStop(0, 'rgba(255,50,0,0.3)');
    sg.addColorStop(1, 'rgba(255,50,0,0)');
    ctx.fillStyle = sg;
    ctx.beginPath(); ctx.ellipse(x - aw + aw * 0.3, y - ah - 10, 20, 20, 0, 0, Math.PI * 2); ctx.fill();
  }

  // Red cross on side
  const crossX = x - aw * 0.4, crossY = y - ah / 2;
  ctx.fillStyle = '#ff2222';
  ctx.fillRect(crossX - 6, crossY - 2, 12, 4);
  ctx.fillRect(crossX - 2, crossY - 6, 4, 12);

  // Windows
  ctx.fillStyle = '#334455';
  ctx.fillRect(x - aw + 5, y - ah + 4, 10, 8);
  ctx.fillRect(x - aw * 0.45, y - ah + 4, 12, 8);

  // Wheels
  ctx.fillStyle = '#222';
  ctx.beginPath(); ctx.arc(x - aw * 0.8, y, 7, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(x - aw * 0.2, y, 7, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = '#444';
  ctx.beginPath(); ctx.arc(x - aw * 0.8, y, 4, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(x - aw * 0.2, y, 4, 0, Math.PI * 2); ctx.fill();

  // Doctor mice (when stopped)
  if (amb.phase === 'stopped') {
    const docT = amb.sparkTimer;
    // Draw 2 small doctor mice
    for (let d = 0; d < 2; d++) {
      const dx = x - aw - 10 - d * 14;
      const dy = y - 20;
      ctx.save();
      ctx.translate(dx, dy);
      ctx.scale(0.5, 0.5);
      // Mini mouse body
      ctx.fillStyle = '#ffffff';
      ctx.beginPath(); ctx.ellipse(0, 0, 10, 14, 0, 0, Math.PI * 2); ctx.fill();
      ctx.fillStyle = '#dddddd';
      ctx.beginPath(); ctx.arc(0, -16, 8, 0, Math.PI * 2); ctx.fill();
      // Red cross on coat
      ctx.fillStyle = '#ff2222';
      ctx.fillRect(-3, -5, 6, 2); ctx.fillRect(-1, -7, 2, 6);
      // Spark animation
      if (Math.floor(docT / 150) % 2 === 0) {
        ctx.strokeStyle = '#ffff00';
        ctx.lineWidth = 2;
        const sOff = d === 0 ? 10 : -10;
        ctx.beginPath();
        ctx.moveTo(sOff, -20);
        ctx.lineTo(sOff + 6, -30);
        ctx.lineTo(sOff + 2, -28);
        ctx.lineTo(sOff + 8, -40);
        ctx.stroke();
      }
      ctx.restore();
    }
  }
}

// ─── Status Colors & Labels ───────────────────────────────────────────────────
function statusColor(s) {
  if (s === 'working') return '#44ee88';
  if (s === 'crashed') return '#ff3333';
  return '#ffaa33';
}
function statusLabel(s) {
  if (s === 'working') return 'Работает';
  if (s === 'crashed') return 'КРАШ 💀';
  return 'Отдыхает';
}

// ─── Main Animation Loop ─────────────────────────────────────────────────────
let lastT = 0;
function render(t) {
  const dt = t - lastT;
  lastT = t;

  const w = W(), h = H();
  ctx.clearRect(0, 0, w, h);

  drawOffice();
  drawDen();

  const stations   = getStations();
  const denSpots   = getDenSpots();

  // Draw mice
  for (let i = 0; i < 8; i++) {
    const agent = agents[i];
    if (!agent) continue;
    const cfg = MOUSE_CONFIGS[i];
    const anim = mouseAnim[i] || {};

    let mx, my;
    if (agent.status === 'working') {
      mx = stations[i].x;
      my = stations[i].y - 5;
    } else if (agent.status === 'idle') {
      // Wander in den spot with gentle oscillation
      const wx = Math.sin(t * 0.0008 + i * 1.3) * (W() * 0.028);
      const wy = Math.cos(t * 0.0012 + i * 0.9) * (H() * 0.022);
      mx = denSpots[i].x + wx;
      my = denSpots[i].y + wy;
    } else {
      // crashed: at station
      mx = stations[i].x;
      my = stations[i].y - 5;
    }

    // Store position for click detection
    if (!mouseAnim[i]) mouseAnim[i] = {};
    mouseAnim[i].screenX = mx;
    mouseAnim[i].screenY = my;

    drawMouse(mx, my, cfg, agent.status, anim, t);

    // Mouse label
    ctx.fillStyle = 'rgba(100,130,180,0.6)';
    ctx.font = `${Math.round(h * 0.012)}px 'Courier New'`;
    ctx.textAlign = 'center';
    const labelY = (agent.status === 'crashed') ? my + 45 : my + 36;
    ctx.fillText(cfg.nameRu, mx, labelY);
    ctx.textAlign = 'left';

    // Status indicator dot under name
    ctx.fillStyle = statusColor(agent.status);
    ctx.beginPath();
    ctx.arc(mx, labelY + 7, 3, 0, Math.PI * 2);
    ctx.fill();

    // Init ambulance for crashed agents
    if (agent.status === 'crashed' && !ambulances[i]) {
      initAmbulance(i);
    }
  }

  // Draw ambulances
  updateAndDrawAmbulances(t, dt);

  // Section labels
  ctx.fillStyle = 'rgba(60,90,150,0.4)';
  ctx.font = `bold ${Math.round(h * 0.018)}px 'Courier New'`;
  ctx.fillText('◼ ОФИС', 10, Math.round(h * 0.045));

  requestAnimationFrame(render);
}

// ─── Click → Popup ───────────────────────────────────────────────────────────
canvas.addEventListener('click', (e) => {
  const rect = canvas.getBoundingClientRect();
  const cx = (e.clientX - rect.left) * (canvas.width / rect.width);
  const cy = (e.clientY - rect.top)  * (canvas.height / rect.height);

  for (let i = 0; i < 8; i++) {
    const a = mouseAnim[i];
    if (!a || a.screenX === undefined) continue;
    const dist = Math.hypot(cx - a.screenX, cy - a.screenY);
    if (dist < 38) {
      showAgentPopup(i);
      return;
    }
  }
  closePopup();
});

function showAgentPopup(idx) {
  const agent = agents[idx];
  const cfg   = MOUSE_CONFIGS[idx];
  if (!agent) return;

  const dotClass = `dot-${agent.status}`;
  const html = `
    <div class="p-name">${cfg.nameRu}</div>
    <div class="p-role">${agent.role || '—'}</div>
    <div class="p-row">
      <span class="p-label">Статус</span>
      <span class="p-val">
        <span class="status-dot ${dotClass}"></span>${statusLabel(agent.status)}
      </span>
    </div>
    <div class="p-row">
      <span class="p-label">Задача</span>
      <span class="p-val">${agent.task || '—'}</span>
    </div>
    <div class="p-row">
      <span class="p-label">Модель</span>
      <span class="p-val">${agent.model || '—'}</span>
    </div>
    <div class="p-row">
      <span class="p-label">Коммиты</span>
      <span class="p-val">🔀 ${agent.commits ?? 0}</span>
    </div>
    <div class="p-row">
      <span class="p-label">Время в работе</span>
      <span class="p-val">⚙️ ${formatMinutes(agent.workMinutes)}</span>
    </div>
    <div class="p-row">
      <span class="p-label">Время в норе</span>
      <span class="p-val">🐀 ${formatMinutes(agent.totalMinutes)}</span>
    </div>
  `;
  document.getElementById('popup-inner').innerHTML = html;
  document.getElementById('popup').style.display = 'block';
  document.getElementById('backdrop').style.display = 'block';
}

function showLimitsPopup(which) {
  const lim = limitsData[which];
  if (!lim) {
    document.getElementById('popup-inner').innerHTML = `<div class="p-name">Нет данных</div>`;
    document.getElementById('popup').style.display = 'block';
    document.getElementById('backdrop').style.display = 'block';
    return;
  }
  const pct = Math.round((lim.used / lim.total) * 100);
  const color = pct > 80 ? '#ff4444' : pct > 50 ? '#ffaa33' : '#44ee88';
  const icon = which === 'claude' ? '🤖' : '✨';
  const name = which === 'claude' ? 'Claude' : 'Gemini';
  const resetDate = lim.resetAt ? new Date(lim.resetAt).toLocaleString('ru-RU') : '—';

  const barFill = `background: linear-gradient(90deg, ${color} ${pct}%, rgba(30,30,50,0.5) ${pct}%)`;
  const html = `
    <div class="p-name">${icon} ${name} API</div>
    <div class="p-role">Лимиты использования</div>
    <div style="margin: 10px 0; height: 12px; border-radius: 6px; border: 1px solid rgba(80,100,150,0.4); ${barFill};"></div>
    <div class="p-row">
      <span class="p-label">Использовано</span>
      <span class="p-val" style="color:${color}">${lim.used} / ${lim.total} (${pct}%)</span>
    </div>
    <div class="p-row">
      <span class="p-label">Единица</span>
      <span class="p-val">${lim.unit || '—'}</span>
    </div>
    <div class="p-row">
      <span class="p-label">Сброс</span>
      <span class="p-val">${resetDate}</span>
    </div>
    ${pct > 80 ? '<div style="color:#ff4444;margin-top:10px;text-align:center">🚨 КРИТИЧЕСКИЙ УРОВЕНЬ!</div>' : ''}
  `;
  document.getElementById('popup-inner').innerHTML = html;
  document.getElementById('popup').style.display = 'block';
  document.getElementById('backdrop').style.display = 'block';
}

function closePopup() {
  document.getElementById('popup').style.display = 'none';
  document.getElementById('backdrop').style.display = 'none';
}

function formatMinutes(mins) {
  if (!mins && mins !== 0) return '—';
  const h = Math.floor(mins / 60);
  const m = mins % 60;
  return h > 0 ? `${h}ч ${m}м` : `${m}м`;
}

// ─── API Limit Buttons Update ─────────────────────────────────────────────────
function updateApiButtons() {
  const providers = ['claude', 'gemini'];
  const btnIds = { claude: 'btn-claude', gemini: 'btn-gemini' };
  const icons  = { claude: '🤖', gemini: '✨' };
  const names  = { claude: 'Claude', gemini: 'Gemini' };

  for (const key of providers) {
    const btn = document.getElementById(btnIds[key]);
    const lim = limitsData[key];
    if (!btn) continue;
    if (lim) {
      const pct = (lim.used / lim.total) * 100;
      btn.textContent = `${pct > 80 ? '🚨' : icons[key]} ${names[key]} ● ${Math.round(pct)}%`;
      btn.classList.toggle('alert', pct > 80);
    } else {
      btn.textContent = `${icons[key]} ${names[key]} ●`;
      btn.classList.remove('alert');
    }
  }
}

// ─── Load Status ─────────────────────────────────────────────────────────────
async function loadStatus() {
  try {
    const r = await fetch('status.json?' + Date.now());
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const data = await r.json();
    agents     = data.agents || [];
    limitsData = data.limits || {};
    updateApiButtons();
  } catch (err) {
    console.warn('status.json load error:', err);
  }
}

setInterval(loadStatus, 30000);
loadStatus();

// ─── Start ───────────────────────────────────────────────────────────────────
requestAnimationFrame(render);
</script>
</body>
</html>
